{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/src/hook.mjs\"",
            "commandWindows": "pwsh -NoProfile -NonInteractive -Command \"& node (Join-Path $env:PLUGIN_ROOT 'src\\hook.mjs')\"",
            "timeout": 10,
            "statusMessage": "Enforcing Codex dispatcher policy"
          }
        ]
      }
    ]
  }
}
